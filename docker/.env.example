# Blue Iris trigger URL template. Bound to BlueIris:TriggerUrlTemplate. The
# template supports {camera}, {label}, {event_id}, {zone} substitutions. There
# is no separate BlueIris:BaseUrl, Username, or Password property — auth is
# expressed in one of two ways:
#
#   1. IP-whitelist on the Blue Iris side (preferred) — Blue Iris admins can
#      add the FrigateRelay container's host to the trusted-IP list, after
#      which trigger requests need no credentials in the URL:
#
#        BLUEIRIS__TRIGGERURLTEMPLATE=http://blueiris.lan:81/admin?camera={camera}&trigger=1
#
#   2. URL-embedded credentials (when whitelist is not an option):
#
#        BLUEIRIS__TRIGGERURLTEMPLATE=http://blueiris.lan:81/admin?camera={camera}&trigger=1&user=<USER>&pw=<PW>
#
# Optional snapshot-source template (only set when using BlueIris as the
# snapshot provider; same {camera}/{label}/{event_id}/{zone} tokens):
#   BLUEIRIS__SNAPSHOTURLTEMPLATE=http://blueiris.lan:81/image/{camera}?q=85
BLUEIRIS__TRIGGERURLTEMPLATE=http://blueiris.lan:81/admin?camera={camera}&trigger=1

# Pushover credentials. Bound to Pushover:* options class. Note: the
# property is AppToken (not ApiToken) — the env var key must be APPTOKEN.
PUSHOVER__APPTOKEN=
PUSHOVER__USERKEY=

# Optional: Frigate snapshot provider. Required only when an action sets
# "SnapshotProvider": "Frigate". Bound to FrigateSnapshot:BaseUrl.
# FRIGATESNAPSHOT__BASEURL=http://frigate.lan:5000

# Optional: CodeProject.AI validator. Bound to a Validators:<name>:* section
# (named-options pattern); set per validator instance, e.g. Validators:Person.
# NOTE: CodeProject.AI active development has stopped — see README.md
# "Validator engine status" before standing up a new install.
# VALIDATORS__PERSON__BASEURL=http://codeproject-ai.lan:32168
# VALIDATORS__PERSON__MINCONFIDENCE=0.6

# Optional: OpenTelemetry OTLP exporter endpoint.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.lan:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf   # uncomment if HTTP/2 issues on Alpine
