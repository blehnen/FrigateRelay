# EditorConfig: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csproj,props,targets}]
indent_style = space
indent_size = 4

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Drive unused-using cleanup across the solution
[*.cs]
dotnet_diagnostic.IDE0005.severity = warning

# Test code relaxes naming + doc-file-dependent rules:
#   CA1707 — DAMP-style underscore naming is the standard test convention.
#   IDE0005 — requires GenerateDocumentationFile=true to run reliably; enabling
#             XML doc files for test assemblies is not worth the noise.
[tests/**.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.IDE0005.severity = none
